require "autorake/mkconfig"

Autorake.configure {

  extending_ruby

  if RUBY_VERSION < "3.3" then  # Always false after March 2026
    # enable :old_feature
  end

  have_header "ruby/ruby.h"
  have_header "ruby/st.h"
  have_header "ruby/io.h"
  have_header "ruby/re.h"

  have_header "sys/vfs.h"
}

